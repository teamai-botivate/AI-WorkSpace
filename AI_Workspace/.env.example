# ===============================================================
# BOTIVATE AI WORKSPACE — ENVIRONMENT CONFIGURATION
# ===============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ===============================================================

# --- App Settings ---
APP_NAME=Botivate AI Workspace
APP_URL=http://localhost:8000
APP_SECRET_KEY=change-this-to-a-strong-random-secret-key

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/workspace.db

# --- JWT Authentication ---
JWT_SECRET_KEY=change-this-to-a-strong-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Groq (Free LLM API) ---
GROQ_API_KEY=

# --- HuggingFace ---
HUGGINGFACE_API_TOKEN=

# --- Google Service Account ---
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/google/service-account.json

# --- Google OAuth ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --- SMTP Email ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chroma

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=2
