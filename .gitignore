# ══════════════════════════════════════════════════════════
#  BOTIVATE AI WORKSPACE — Master .gitignore
#  Covers: Gateway, Frontend Shell, HR_Support, Resume-Screening-Agent
# ══════════════════════════════════════════════════════════

# ─── Environment & Secrets (CRITICAL — NEVER COMMIT) ─────
.env
.env.local
.env.production
.env.staging
*.env

# ─── Google / OAuth Credentials ──────────────────────────
credentials.json
token.json
token.pickle
service-account.json
client_secret*.json
oauth_*.json
*.pem
*.key
*.cert
**/tokens/

# ─── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
*.log
backend.log

# ─── Node.js ─────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ─── Vector Databases ────────────────────────────────────
chroma_data/
chroma_db/
chromadb/
*.sqlite3
*.sqlite
*.db

# ─── Uploaded Files & Reports ─────────────────────────────
uploads/
Reports/
temp/
*.tmp
*.bak

# ─── Build Outputs ───────────────────────────────────────
dist/
build/
.next/
out/

# ─── IDE & OS ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# ─── Agent/Debug Tracking ────────────────────────────────
.gemini/
.agents/
.agent/
_agents/
_agent/
debug_last_prompt.txt
assessments_db.json
MANUAL_UPDATE.txt

# ─── Misc ─────────────────────────────────────────────────
*.bak
*.tmp
screenshots/
