{
  "workspace": {
    "name": "Botivate",
    "tagline": "AI-Powered Workforce Management",
    "version": "1.0.0",
    "theme": {
      "primaryColor": "#6366f1",
      "accentColor": "#8b5cf6",
      "mode": "light"
    }
  },
  "gateway": {
    "port": 9000,
    "corsOrigins": ["http://localhost:3000", "http://localhost:5173"]
  },
  "agents": [
    {
      "id": "hr-recruiter",
      "name": "HR Recruiter & Screener",
      "description": "JD Generation, Resume Screening, AI Scoring & Automated Outreach",
      "icon": "UserSearch",
      "gradient": ["#3b82f6", "#1d4ed8"],
      "status": "active",
      "category": "Human Resources",
      "features": ["JD Generator", "Resume Screening", "Aptitude Tests", "Email Automation"],
      "backend": {
        "port": 8000,
        "healthCheck": "/docs",
        "startCommand": "uvicorn app.unified_server:app --port 8000 --reload",
        "workDir": "Resume-Screening-Agent/Backend",
        "envFile": "Resume-Screening-Agent/.env",
        "activateVenv": "Resume-Screening-Agent/.venv/Scripts/Activate.ps1"
      },
      "frontend": {
        "port": 5174,
        "url": "http://localhost:5174",
        "type": "static",
        "startCommand": "python -m http.server 5174",
        "workDir": "Resume-Screening-Agent/Frontend"
      }
    },
    {
      "id": "hr-support",
      "name": "HR Employee Support",
      "description": "Leave Management, Policy Queries, Grievances & Approval Workflows",
      "icon": "Headphones",
      "gradient": ["#10b981", "#059669"],
      "status": "active",
      "category": "Human Resources",
      "features": ["Leave Management", "Policy RAG", "Approval Workflows", "Employee Lifecycle"],
      "backend": {
        "port": 8001,
        "healthCheck": "/docs",
        "startCommand": "uvicorn app.main:app --port 8001 --reload",
        "workDir": "HR_Support/backend",
        "envFile": "HR_Support/backend/.env",
        "activateVenv": "HR_Support/backend/.venv/Scripts/Activate.ps1"
      },
      "frontend": {
        "port": 5175,
        "url": "http://localhost:5175",
        "type": "vite",
        "startCommand": "npm run dev -- --port 5175",
        "workDir": "HR_Support/frontend",
        "env": {
          "VITE_API_URL": "http://localhost:8001"
        }
      }
    }
  ]
}
